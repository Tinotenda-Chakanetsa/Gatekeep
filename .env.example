# Backend (Django)
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=*
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# Where captured plate images are stored.
MEDIA_ROOT=/app/media

# Auth (JWT)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS — origins allowed to call the API cross-origin (Vite dev server).
# Only needed during local `npm run dev`; same-origin in the nginx build.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Plate matching tolerance: max edit distance for a fuzzy OCR match (0 disables fuzzy).
PLATE_FUZZY_MAX_DISTANCE=1
# Seconds a manual "open gate" command stays pending for the device to poll.
GATE_COMMAND_TTL_SECONDS=30

# Initial seeded admin account (used by `manage.py seed_data`).
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=admin12345

# Frontend (nginx)
# In docker-compose this resolves via the internal network. On a cloud platform
# (Render/Railway/Fly), set this to the public URL of the deployed backend service,
# e.g. https://ocr-backend.up.railway.app
BACKEND_URL=http://backend:8000
